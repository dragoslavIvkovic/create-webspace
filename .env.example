# Resend (https://resend.com/docs/send-with-astro) — obavezno za kontakt formu
RESEND_API_KEY=re_xxxxxxxx
# Verifikovani domen u Resend-u, npr. "CreateWebPlace <brief@createwebplace.rs>"
CONTACT_FROM=
# Jedna ili više adresa za prijem upita (odvojene zarezom u kodu ako proširite API)
CONTACT_TO=

# Wrangler (Cloudflare): iste vrednosti u `.dev.vars` lokalno — Wrangler ne učitava `.env` za Worker.
