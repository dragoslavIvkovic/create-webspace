# Za `wrangler dev` kopiraj ove vrednosti i u `.dev.vars` (isti format kao .env).
# Resend (https://resend.com/docs/send-with-astro) — obavezno za kontakt formu
RESEND_API_KEY=re_xxxxxxxx
# Samo email (najmanje problema sa < > u Cloudflare UI). Ili "Ime <email@domen>" ako oba znaka <>
# ostaju netaknuta u Variables.
# Mora biti adresa na domenu koji je verifikovan u Resend-u (isti kao javni sajt ako šalješ sa njega).
CONTACT_FROM=brief@createwebplace.com
CONTACT_TO=dragoslav.m.ivkovic@gmail.com
