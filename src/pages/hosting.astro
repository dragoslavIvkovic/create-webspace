---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title={'Hosting | CreateWebPlace'}
  dataPage={'hosting'}
  bodyClass={'subpage'}
  headerClass={'scrolled'}
  activeSection={'services'}
  isHome={false}
>
  <main id="main-content">
    <section class="section page-hero">
      <div class="container">
        <span class="subtitle" data-i18n="p:hero_k">Premium Infrastruktura</span>
        <h1 data-i18n-html="p:hero_h_html">Munjevit <span class="gradient-text">Hosting</span></h1>
        <p class="hero-subtext" data-i18n="p:hero_sub">
          Vaš sajt zaslužuje najbolje. Obezbeđujemo stabilnost, brzinu i sigurnost na enterprise
          nivou.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container grid-2">
        <div class="text-content reveal-up">
          <h2 data-i18n="p:h2_performance">Performanse bez kompromisa</h2>
          <p data-i18n="p:p_perf1">
            U svetu gde svaka sekunda učitavanja utiče na prodaju, ne prepuštamo ništa slučaju. Naši
            serveri su optimizovani specijalno za moderne web aplikacije i e-commerce platforme,
            koristeći najnovije NVMe diskove i LiteSpeed tehnologiju.
          </p>
          <p data-i18n="p:p_perf2">99.9% uptime garancija nije samo obećanje — to je standard.</p>
        </div>
        <div class="visual-content reveal-up">
          <div class="stat-grid-simple">
            <div class="stat-item">
              <span class="number" data-target="99">0</span>.9%
              <p data-i18n="p:stat_uptime">Zagarantovan Uptime</p>
            </div>
            <div class="stat-item">
              <span class="number" data-target="100">0</span>%
              <p data-i18n="p:stat_ssd">SSD/NVMe Storage</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section" style="background: var(--card-bg);">
      <div class="container">
        <div class="section-header center reveal-up">
          <span class="subtitle" data-i18n="p:sec_k">Sigurnost i Brzina</span>
          <h2 data-i18n="p:sec_h">Karakteristike Našeg Hostinga</h2>
        </div>
        <div class="services-grid-new">
          <div class="sv3-card reveal-up">
            <div class="sv3-content">
              <h3 data-i18n="p:card_backup_h">Dnevni Backup</h3>
              <p data-i18n="p:card_backup_p">
                Vaši podaci su sigurni. Automatski čuvamo kopije vašeg sajta svakog dana, tako da
                uvek možete da se vratite korak unazad.
              </p>
            </div>
          </div>
          <div class="sv3-card reveal-up">
            <div class="sv3-content">
              <h3 data-i18n="p:card_ssl_h">SSL Sertifikati</h3>
              <p data-i18n="p:card_ssl_p">
                Svi naši hosting paketi uključuju besplatne SSL sertifikate kako bi vaš sajt bio
                siguran i Google-friendly.
              </p>
            </div>
          </div>
          <div class="sv3-card reveal-up">
            <div class="sv3-content">
              <h3 data-i18n="p:card_support_h">Lokalna Podrška</h3>
              <p data-i18n="p:card_support_p">
                Naš tim stručnjaka je tu 24/7 da reši bilo koji tehnički izazov, bez čekanja na
                tikete i duge redove.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section service-contact-cta" aria-label="Kontakt forma">
      <div class="container">
        <div class="cwp-contact-shell cwp-contact-shell--section reveal-up">
          <ContactForm variant="page" defaultCategory="hosting" source="hosting.html" />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
