---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title={'Digitalni Meni | CreateWebPlace'}
  dataPage={'digitalni-meni'}
  bodyClass={'subpage'}
  headerClass={'scrolled'}
  activeSection={'services'}
  isHome={false}
>
  <main>
    <section class="section page-hero">
      <div class="container">
        <span class="subtitle" data-i18n="p:hero_k">Ugostiteljstvo 2.0</span>
        <h1 data-i18n-html="p:hero_h_html">Digitalni <span class="gradient-text">Meni</span></h1>
        <p class="hero-subtext" data-i18n="p:hero_sub">
          Modernizujte svoj restoran ili kafić uz beskontaktne menije koji povećavaju prodaju i
          oduševljavaju goste.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container grid-2">
        <div class="text-content reveal-up">
          <h2>Bezbedno, Brzo i Interaktivno</h2>
          <p>
            Tradicionalni štampani meniji postaju stvar prošlosti. Naš digitalni meni omogućava
            vašim gostima da skeniraju QR kod i trenutno pristupe vašoj ponudi na svom telefonu. Bez
            instalacije aplikacija, bez čekanja.
          </p>
          <p>Promenite cene ili dnevnu ponudu u sekundi — bez ponovnog štampanja.</p>
        </div>
        <div class="visual-content reveal-up">
          <div class="stat-grid-simple">
            <div class="stat-item">
              <span class="number" data-target="100">0</span>%
              <p>Beskontaktno i higijenski</p>
            </div>
            <div class="stat-item">
              <span class="number" data-target="25">0</span>%
              <p>Prosečan rast porudžbina</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section" style="background: var(--card-bg);">
      <div class="container">
        <div class="section-header center reveal-up">
          <span class="subtitle">Funkcionalnosti</span>
          <h2>Više od običnog PDF-a</h2>
        </div>
        <div class="services-grid-new">
          <div class="sv3-card reveal-up">
            <div class="sv3-content">
              <h3>Vizuelni Identitet</h3>
              <p>
                Prilagođavamo dizajn menija vašem brendu sa visokokvalitetnim fotografijama jela
                koje podstiču apetit.
              </p>
            </div>
          </div>
          <div class="sv3-card reveal-up">
            <div class="sv3-content">
              <h3>Brza Ažuriranja</h3>
              <p>
                Intuitivni administratorski panel za laku promenu cena, sastojaka ili dodavanje
                novih artikala.
              </p>
            </div>
          </div>
          <div class="sv3-card reveal-up">
            <div class="sv3-content">
              <h3>Višejezičnost</h3>
              <p>
                Automatski prevod menija na svetske jezike, olakšavajući naručivanje stranim
                turistima.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section service-contact-cta" aria-label="Kontakt forma">
      <div class="container">
        <div class="cwp-contact-shell cwp-contact-shell--section reveal-up">
          <ContactForm
            variant="page"
            defaultCategory="digitalni-meni"
            source="digitalni-meni.html"
          />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
