---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
---

<BaseLayout
  title={'CreateWebPlace | Web stranice i mobilne aplikacije — glavna SEO tačka'}
  description={'Imperativ su kvalitetna web stranica i mobilna aplikacija: to je glavna SEO tačka za organiku i upite. CreateWebPlace projektuje, gradi i objavljuje sajtove, prodavnice i mobilna iskustva — UX, performanse, tehnički SEO, hosting i integracije.'}
  keywords={'web stranice SEO, mobilne aplikacije SEO, izrada web sajtova, iOS Android aplikacije, web dizajn Srbija, digitalna agencija, SEO optimizacija'}
  canonical={'https://createwebplace.com/index.html'}
  dataPage={'index'}
  bodyId={'top'}
  activeSection={null}
  isHome={true}
>
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://createwebplace.com/" />
    <meta
      property="og:title"
      content="CreateWebPlace | Web, mobilne aplikacije — imperativ za SEO"
    />
    <meta
      property="og:description"
      content="Web stranice i mobilne aplikacije su imperativ — srž SEO‑a koji donosi organiku. Dizajn, razvoj i objava uz brzinu, jasnu strukturu i tehnički SEO."
    />
    <meta property="og:image" content="https://createwebplace.com/assets/og-image.jpg" />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://createwebplace.com/" />
    <meta property="twitter:title" content="CreateWebPlace | Web i mobilne aplikacije za SEO" />
    <meta
      property="twitter:description"
      content="Uložite prvo u web i mobilne aplikacije — to je glavna SEO tačka. Sajtovi, prodavnice i mobilna iskustva prilagođeni vašem biznisu."
    />
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "CreateWebPlace",
        "image": "https://createwebplace.com/assets/logo.png",
        "@id": "https://createwebplace.com",
        "url": "https://createwebplace.com",
        "telephone": "+381111234567",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Bulevar Kralja Aleksandra",
          "addressLocality": "Beograd",
          "postalCode": "11000",
          "addressCountry": "RS"
        },
        "geo": { "@type": "GeoCoordinates", "latitude": 44.8125, "longitude": 20.4612 },
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "09:00",
          "closes": "17:00"
        },
        "sameAs": [
          "https://www.facebook.com/people/Izrada-web-sajta-povoljno/61564686248403/",
          "https://www.linkedin.com/in/dragoslav-ivkovic-104b68383/"
        ]
      }
    </script>
  </Fragment>
  <main id="main-content">
    <!-- Section 1: Hero -->
    <section id="hero" class="hero-section">
      <div class="hero-bg-wrapper">
        <div class="hero-overlay"></div>
      </div>
      <div class="container">
        <div class="hero-wrapper-grid">
          <div class="hero-text-wrapper hero-content-left">
            <span
              class="subtitle hero-subtitle"
              data-i18n="p:hero.subtitle"
              style="color: var(--main-color);"
              >Web stranice i mobilne aplikacije — imperativ za SEO</span
            >
            <h1 class="reveal-text" data-i18n="p:hero.h1">
              Uložite u sajt i mobilnu aplikaciju: to je glavna SEO tačka koja nosi organiku i
              upite.
            </h1>
            <p class="hero-subline reveal-up" data-i18n="p:hero.subline">
              Projektujemo, građimo i objavljujemo poslovne sajtove, web prodavnice i mobilna
              iskustva koja pretraživači mogu pouzdano da indeksiraju — jasno pozicioniranje, uredan
              dizajn i merljive performanse, bez generičkih šablona.
            </p>
            <div class="hero-btns reveal-up">
              <a href="kontakt.html" class="btn-primary hero-btn" data-i18n="p:hero.cta_primary"
                >Započnite kratki brief za sajt</a
              >
              <a
                href="#portfolio"
                class="btn-outline hero-btn-outline"
                data-i18n="p:hero.cta_outline">Pogledajte naše sajtove uživo</a
              >
            </div>
          </div>
          <div class="hero-visual-wrapper reveal-right">
            <div class="hero-visual-inner">
              <div class="hero-circle-bg">
                <Image
                  src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=600&auto=format&fit=crop"
                  data-i18n-alt="p:hero.portrait_alt"
                  alt="Tim na sastanku o strukturi sajta i objavi"
                  class="hero-portrait-img"
                  width={600}
                  height={600}
                  decoding="async"
                  loading="eager"
                  fetchpriority="high"
                />
              </div>
            </div>
            <!-- Floating Badges -->

            <div class="floating-badge badge-2">
              <div class="badge-icon">⚡</div>
              <div class="badge-text">
                <h4 data-i18n="p:hero.badge_web_title">Celovita isporuka</h4>
                <p data-i18n="p:hero.badge_web_sub">
                  Dizajn → QA → objava — web i mobilno iskustvo.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="services" class="section section-bg-pattern-b">
      <div class="container">
        <div class="section-header center reveal-up">
          <span class="subtitle" style="color: #FF8359;" data-i18n="p:services.kicker"
            >Šta isporučujemo</span
          >
          <h2 data-i18n="p:services.h2">
            Prvo web stranice i mobilne aplikacije — glavna SEO tačka; zatim alati za rast
          </h2>
        </div>

        <div class="services-showcase">
          <article class="service-showcase-card reveal-up">
            <div class="service-showcase-card__visual">
              <Image
                src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?q=80&w=1200&auto=format&fit=crop"
                data-i18n-alt="p:services.card1_alt"
                alt="Rad na razvoju web platformi na laptopu"
                width={600}
                height={375}
                decoding="async"
                loading="lazy"
                class="service-showcase-card__img"
              />
              <span class="service-showcase-card__shine" aria-hidden="true"></span>
            </div>
            <div class="service-showcase-card__accent" aria-hidden="true"></div>
            <div class="service-showcase-card__body">
              <h3 data-i18n="p:services.card1_title">
                Prilagođeni poslovni sajtovi i web platforme
              </h3>
              <p data-i18n="p:services.card1_p">
                Struktura stranica, UX, vizuelni jezik i kod usmereni na jedan cilj — da posetilac
                odmah razume šta nudite, a pretrage mogu pouzdano da indeksiraju sadržaj.
              </p>
              <a href="usluge.html" class="text-link" data-i18n="p:services.card1_link"
                >Pregled ponude za sajt »</a
              >
            </div>
          </article>
          <article
            class="service-showcase-card service-showcase-card--alt reveal-up"
            style="transition-delay: 0.06s;"
          >
            <div class="service-showcase-card__visual">
              <Image
                src="https://images.unsplash.com/photo-1512941937669-90a1b58e7e9c?q=80&w=1200&auto=format&fit=crop"
                data-i18n-alt="p:services.card2_alt"
                alt="Mobilni telefon — aplikacije i UX u upotrebi"
                width={600}
                height={375}
                decoding="async"
                loading="lazy"
                class="service-showcase-card__img"
              />
              <span class="service-showcase-card__shine" aria-hidden="true"></span>
            </div>
            <div
              class="service-showcase-card__accent service-showcase-card__accent--alt"
              aria-hidden="true"
            >
            </div>
            <div class="service-showcase-card__body">
              <h3 data-i18n="p:services.card2_title">Mobilni UI i prateći interfejsi</h3>
              <p data-i18n="p:services.card2_p">
                Kada prezentacija na webu nije dovoljna — dizajniramo prilagođena iskustva za
                telefon koja prate vaš sajt i brend, bez hirovitih odstupanja na drugim uređajima.
              </p>
              <a href="web-dizajn.html" class="text-link" data-i18n="p:services.card2_link"
                >Kako radimo dizajn UX/UI »</a
              >
            </div>
          </article>
        </div>

        <div class="services-footer reveal-up">
          <p>
            <span data-i18n="p:services.footer_p_intro"
              >Čitav spektar usluga jednim klikom —
            </span><strong data-i18n="p:services.footer_p_mid"
              >strateški raspored šta ima smisla prvo</strong
            >. <a href="usluge.html" class="sv3-link-inline" data-i18n="p:services.footer_link"
              >Pregled svega što radimo</a
            >
          </p>
        </div>
      </div>
    </section>

    <!-- Section 3: Google Business Profile (firme, majstori) -->
    <section id="google-poslovni-profil" class="section gb-profile-section section-bg-pattern-a">
      <div class="container">
        <div class="section-header center reveal-up">
          <span class="subtitle gb-profile-section__subtitle" data-i18n="p:gb.subtitle"
            >Google i lokal</span
          >
          <h2 data-i18n="p:gb.h2">Istaknite firmu na Google Pretrazi i Google Kartama</h2>
        </div>
        <div class="gb-profile-section__cards reveal-up">
          <div class="gb-profile-cards gb-profile-cards--aligned">
            <article class="gb-profile-card">
              <div class="gb-profile-card__glow" aria-hidden="true"></div>
              <p class="gb-profile-card__kicker" data-i18n="p:gb.card1_kicker">
                Profil na Google‑u
              </p>
              <h3 class="gb-profile-card__title" data-i18n="p:gb.card1_title">
                Pretraga i Karte koje donose upite
              </h3>
              <p class="gb-profile-card__text" data-i18n-html="p:gb.card1_html">
                Pomažemo firmama i majstorima da <strong
                  >profesionalno postave i vode poslovni profil</strong
                > (Google Business Profile): tačne kategorije, radna zona, vizuelni materijal i tekstovi
                koji vuku pozive iz pretrage — ne prazan broj pregleda.
              </p>
              <ul class="check-list gb-profile-card__list">
                <li data-i18n="p:gb.card1_li1">
                  Istaknuto mesto u „Maps“ i pojmovi kojima stvarno konkurišete (npr. „u blizini“,
                  naziv usluge).
                </li>
                <li data-i18n="p:gb.card1_li2">
                  Spoj sa vašim sajtom i Local SEO kada budete spremni na širi domet.
                </li>
              </ul>
              <div class="gb-profile-card__chips">
                <span class="gb-profile-card__chip" data-i18n="p:gb.chip_maps">Maps</span>
                <span class="gb-profile-card__chip" data-i18n="p:gb.chip_search">Pretraga</span>
                <span class="gb-profile-card__chip" data-i18n="p:gb.chip_categories"
                  >Kategorije</span
                >
              </div>
              <div class="gb-profile-card__links">
                <a href="local-seo.html" class="text-link" data-i18n="p:gb.link_local"
                  >Lokalna strategija i profil — detaljnije &raquo;</a
                >
              </div>
            </article>
            <article class="gb-profile-card gb-profile-card--alt">
              <div class="gb-profile-card__glow" aria-hidden="true"></div>
              <p class="gb-profile-card__kicker" data-i18n="p:gb.card2_kicker">
                Šta klijent vidi prvo
              </p>
              <h3 class="gb-profile-card__title" data-i18n="p:gb.card2_title">
                Poverenje pre prvog klika na sajt
              </h3>
              <p class="gb-profile-card__text" data-i18n-html="p:gb.card2_html">
                <strong>Poslovni profil</strong> je često prva kartica koju vide pre sajta: sati, telefon,
                lokacija, ponuda, recenzije — tu se gubi ili dobija poverenje. Uređujemo i održavamo taj
                prikaz uz jasnu poruku i trag na šta konkretno reaguju ljudi.
              </p>
              <ul class="check-list gb-profile-card__list">
                <li data-i18n="p:gb.card2_li1">
                  Recenzije i odgovori koji grade ugled — ne statistika radi brojki.
                </li>
                <li data-i18n="p:gb.card2_li2">
                  Fotografije i opis usluge kao završen prikaz, ne kopirani šablon.
                </li>
              </ul>
              <div class="gb-profile-card__chips">
                <span class="gb-profile-card__chip" data-i18n="p:gb.chip_reviews">Recenzije</span>
                <span class="gb-profile-card__chip" data-i18n="p:gb.chip_hours">Radno vreme</span>
                <span class="gb-profile-card__chip" data-i18n="p:gb.chip_photo">Foto</span>
              </div>
              <div class="gb-profile-card__links">
                <a
                  href="google-maps.html"
                  class="text-link gb-profile-card__link-secondary"
                  data-i18n="p:gb.link_maps">Google Karte za biznis — šta sve ulazi &raquo;</a
                >
              </div>
            </article>
          </div>
        </div>
      </div>
    </section>

    <!-- Posle objave: održavanje, sadržaj, upiti (vezano za sajt) -->
    <section
      id="automacija-poslovanja"
      class="section gb-profile-section section-bg-pattern-b automacija-section"
    >
      <div class="container">
        <div class="section-header center reveal-up">
          <span
            class="subtitle gb-profile-section__subtitle automacija-section__subtitle"
            data-i18n="p:auto_sec.subtitle">Posle objave</span
          >
          <h2 data-i18n="p:auto_sec.h2">
            Sajt koji i dalje „radi“ — sadržaj, upiti i manje haosa u komunikaciji
          </h2>
          <p class="auto-biz-lead reveal-up" data-i18n="p:auto_sec.lead">
            Prvo gradimo i objavljujemo sajt. Zatim — po potrebi — pomažemo oko reda objava, formi
            koje stižu kao upiti, zakazivanja i jasnih izveštaja da znate šta donosi klijente.
          </p>
        </div>
        <div class="gb-profile-section__cards reveal-up">
          <div class="gb-profile-cards gb-profile-cards--aligned">
            <article class="gb-profile-card">
              <div class="gb-profile-card__glow" aria-hidden="true"></div>
              <p class="gb-profile-card__kicker" data-i18n="p:auto_sec.c1_k">Objave i vidljivost</p>
              <h3 class="gb-profile-card__title" data-i18n="p:auto_sec.c1_t">
                Uredan kalendar sadržaja koji podržava sajt
              </h3>
              <p class="gb-profile-card__text" data-i18n-html="p:auto_sec.c1_html">
                Sajt bez svežeg sadržaja brzo deluje zastarelo. <strong
                  >Postavljamo strukturu tema, ton i red objava</strong
                > (stranice usluga, primeri radova, odgovori na česta pitanja) — da sajt raste sa vama,
                a pretraga vidi kontinuitet umesto zamrznutog brošurijskog teksta.
              </p>
              <ul class="check-list gb-profile-card__list">
                <li data-i18n="p:auto_sec.c1_li1">
                  Teme iz realnih pitanja klijenata — ne prazni SEO tekstovi.
                </li>
                <li data-i18n="p:auto_sec.c1_li2">
                  Ključne fraze organski, bez lomljenja čitljivosti na srpskom.
                </li>
              </ul>
              <div class="gb-profile-card__chips">
                <span class="gb-profile-card__chip" data-i18n="p:auto_sec.chip_blog"
                  >Sadržaj sajta</span
                >
                <span class="gb-profile-card__chip" data-i18n="p:auto_sec.chip_publish"
                  >Red objava</span
                >
                <span class="gb-profile-card__chip" data-i18n="p:auto_sec.chip_local"
                  >Lokal SEO</span
                >
              </div>
              <div class="gb-profile-card__links">
                <a
                  href="seo-optimizacija.html"
                  class="text-link"
                  data-i18n="p:auto_sec.link_blogseo">Kako sadržaj hrani pretragu »</a
                >
              </div>
            </article>
            <article class="gb-profile-card gb-profile-card--alt">
              <div class="gb-profile-card__glow" aria-hidden="true"></div>
              <p class="gb-profile-card__kicker" data-i18n="p:auto_sec.c2_k">Termini i poruke</p>
              <h3 class="gb-profile-card__title" data-i18n="p:auto_sec.c2_t">
                Manje copy‑paste poruka — jasnije zakazivanje
              </h3>
              <p class="gb-profile-card__text" data-i18n-html="p:auto_sec.c2_html">
                Preko forme ili linka za zakazivanje na sajtu: <strong>isti kalendar</strong>, SMS
                ili WhatsApp potvrde i podsetnici. Za salone, servise i konsultacije — <strong
                  >manje no‑show‑ova</strong
                > i bolje iskorišćeno vreme.
              </p>
              <ul class="check-list gb-profile-card__list">
                <li data-i18n="p:auto_sec.c2_li1">
                  Upit ili termin sa sajta → obaveštenje vama + automatska potvrda klijentu.
                </li>
                <li data-i18n="p:auto_sec.c2_li2">
                  Diskretan podsetnik za recenziju nakon dobrog iskustva.
                </li>
              </ul>
              <div class="gb-profile-card__chips">
                <span class="gb-profile-card__chip" data-i18n="p:auto_sec.chip_schedule"
                  >Termini</span
                >
                <span class="gb-profile-card__chip" data-i18n="p:auto_sec.chip_sms"
                  >SMS / WhatsApp</span
                >
                <span class="gb-profile-card__chip" data-i18n="p:auto_sec.chip_gap">No‑show</span>
              </div>
              <div class="gb-profile-card__links">
                <a
                  href="kontakt.html"
                  class="text-link gb-profile-card__link-secondary"
                  data-i18n="p:auto_sec.link_flow">Prođimo vaš proces zajedno »</a
                >
              </div>
            </article>
          </div>
        </div>
        <div class="value-stack reveal-up" data-component="value-stack">
          <header class="value-stack__header">
            <p class="value-stack__eyebrow" data-i18n="p:auto_sec.stack_eyebrow">
              Šta dobijate uz sajt
            </p>
            <h3 class="value-stack__title" data-i18n="p:auto_sec.stack_title">
              Produkcijski spreman sajt — i sistem koji čuva vaše vreme
            </h3>
            <p class="value-stack__lead" data-i18n="p:auto_sec.stack_lead">
              Počinjemo od jasnog cilja: struktura, dizajn, performanse i objava. Kada ste spremni,
              povezujemo praktičan sloj (upiti, red sadržaja, lake integracije) da sajt ne ostane
              „lepa slika bez efekta“.
            </p>
          </header>
          <ul class="value-stack__grid">
            <li class="value-stack__item">
              <span class="value-stack__index" aria-hidden="true">01</span>
              <div class="value-stack__body">
                <h4 class="value-stack__item-title" data-i18n="p:auto_sec.stack_item1_title">
                  Dizajn i kod oko vaše ponude
                </h4>
                <p class="value-stack__item-desc" data-i18n="p:auto_sec.stack_item1_desc">
                  Jedinstven raspored sekcija, tipografija i komponenti koje možete ponavljati — ne
                  generički šablon koji liči na hiljadu drugih sajtova.
                </p>
              </div>
            </li>
            <li class="value-stack__item">
              <span class="value-stack__index" aria-hidden="true">02</span>
              <div class="value-stack__body">
                <h4 class="value-stack__item-title" data-i18n="p:auto_sec.stack_item2_title">
                  Performanse na telefonu
                </h4>
                <p class="value-stack__item-desc" data-i18n="p:auto_sec.stack_item2_desc">
                  Brzo učitavanje, čitljivost i pouzdani breakpoints — posebno važno za lokalnu
                  pretragu i oglasne destinacije na mobilnom.
                </p>
              </div>
            </li>
            <li class="value-stack__item">
              <span class="value-stack__index" aria-hidden="true">03</span>
              <div class="value-stack__body">
                <h4 class="value-stack__item-title" data-i18n="p:auto_sec.stack_item3_title">
                  Forme i upiti koji stižu na pravo mesto
                </h4>
                <p class="value-stack__item-desc" data-i18n="p:auto_sec.stack_item3_desc">
                  Strukturisani upiti (mejl/table/CRM šabloni), potvrde klijentu i trag u evidenciji
                  — manje izgubljenih poruka iz kontakt forme.
                </p>
              </div>
            </li>
            <li class="value-stack__item">
              <span class="value-stack__index" aria-hidden="true">04</span>
              <div class="value-stack__body">
                <h4 class="value-stack__item-title" data-i18n="p:auto_sec.stack_item4_title">
                  SEO i Google slojevi bez šuma
                </h4>
                <p class="value-stack__item-desc" data-i18n="p:auto_sec.stack_item4_desc">
                  Tehnički SEO temelji, meta podaci po stranicama i usklađivanje sa Google profilom
                  kada je biznis lokalan ili uslužni.
                </p>
              </div>
            </li>
            <li class="value-stack__item">
              <span class="value-stack__index" aria-hidden="true">05</span>
              <div class="value-stack__body">
                <h4 class="value-stack__item-title" data-i18n="p:auto_sec.stack_item5_title">
                  Merenje koja donosi odluku
                </h4>
                <p class="value-stack__item-desc" data-i18n="p:auto_sec.stack_item5_desc">
                  Vidite koja stranica i koji kanal (organsko, Maps, kampanja) dovodi zakazivanja
                  ili upite — da budžet ide tamo gde se isplati.
                </p>
              </div>
            </li>
          </ul>
          <p class="value-stack__footer" data-i18n-html="p:auto_sec.stack_cta_line">
            <strong>Sve usklađujemo sa budžetom</strong> — bez obećanja „čarobnjaka“, uz jasne korake.
            <a href="kontakt.html" class="sv3-link-inline value-stack__cta-link"
              >Zakažite kratak razgovor o sajtu</a
            >
          </p>
        </div>
      </div>
    </section>

    <!-- Section 4: Portfolio -->
    <section id="portfolio" class="section section-bg-pattern-b">
      <div class="container">
        <div class="section-header center reveal-up">
          <span class="subtitle" data-i18n="p:portfolio.subtitle">Portfolio</span>
