---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title={'Geo Optimizacija | CreateWebPlace'}
  dataPage={'geo-optimizacija'}
  bodyClass={'subpage'}
  headerClass={'scrolled'}
  activeSection={'services'}
  isHome={false}
>
  <main>
    <section class="section page-hero">
      <div class="container">
        <span class="subtitle" data-i18n="p:hero_k">Napredna Usluga</span>
        <h1 data-i18n-html="p:hero_h_html">Geo <span class="gradient-text">Optimizacija</span></h1>
        <p class="hero-subtext" data-i18n="p:hero_sub">
          Pozicionirajte svoj biznis tamo gde se odluke donose — u odgovorima veštačke inteligencije
          i lokalnim pretragama.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container grid-2">
        <div class="text-content reveal-up">
          <h2>Budućnost pretrage je stigla</h2>
          <p>
            Klasičan SEO više nije dovoljan. Sa usponom AI asistenata (ChatGPT, Perplexity, Google
            Gemini), način na koji klijenti pronalaze usluge se menja. Geo Optimizacija osigurava da
            vaši podaci budu precizno mapirani i razumljivi algoritmima.
          </p>
          <p>Mi ne optimizujemo samo za ključne reči, već za **kontekst i lokaciju**.</p>
        </div>
        <div class="visual-content reveal-up">
          <div class="stat-grid-simple">
            <div class="stat-item">
              <span class="number" data-target="93">0</span>%
              <p>Korisnika koristi mape za lokalne usluge</p>
            </div>
            <div class="stat-item">
              <span class="number" data-target="70">0</span>%
              <p>Veća vidljivost u AI odgovorima</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section" style="background: var(--card-bg);">
      <div class="container">
        <div class="section-header center reveal-up">
          <span class="subtitle">Šta dobijate</span>
          <h2>Komponente Geo Strategije</h2>
        </div>
        <div class="services-grid-new">
          <div class="sv3-card reveal-up">
            <div class="sv3-content">
              <h3>AI Mapiranje</h3>
              <p>
                Strukturiranje podataka tako da AI asistenti prepoznaju vašu tačnu lokaciju i
                dostupnost u realnom vremenu.
              </p>
            </div>
          </div>
          <div class="sv3-card reveal-up">
            <div class="sv3-content">
              <h3>Lokalni Autoritet</h3>
              <p>
                Izgradnja mreže digitalnih potvrda koje potvrđuju vašu relevantnost u određenom
                geografskom području.
              </p>
            </div>
          </div>
          <div class="sv3-card reveal-up">
            <div class="sv3-content">
              <h3>Multi-platform Presence</h3>
              <p>
                Sinhronizacija podataka na svim ključnim mapama: Google, Apple Maps, Bing i
                specijalizovani lokalni direktorijumi.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section service-contact-cta" aria-label="Kontakt forma">
      <div class="container">
        <div class="cwp-contact-shell cwp-contact-shell--section reveal-up">
          <ContactForm variant="page" defaultCategory="geo" source="geo-optimizacija.html" />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
