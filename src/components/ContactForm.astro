---
import { CONTACT_CATEGORY_SLUGS } from '../lib/contact-categories';
import type { ContactCategorySlug } from '../lib/contact-categories';

interface Props {
  variant?: 'page' | 'compact' | 'modal';
  defaultCategory?: ContactCategorySlug;
  /** Kratak opis stranice (npr. putanja ili data-page) za interni kontekst u mejlu */
  source?: string;
}

const { variant = 'page', defaultCategory = 'general', source = '' } = Astro.props;

const formId = `cwp-cf-${Math.random().toString(36).slice(2, 11)}`;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const apiUrl = `${base}/api/contact`;

const variantClass =
  variant === 'compact'
    ? 'cwp-contact--compact'
    : variant === 'modal'
      ? 'cwp-contact--modal'
      : 'cwp-contact--page';

const catI18n = (slug: string) => `c:contact_form.cat_${slug.replace(/-/g, '_')}`;

const defaultLabels: Record<ContactCategorySlug, string> = {
  'web-dizajn': 'Web dizajn i UX/UI',
  'web-shop': 'Web shop / e‑commerce',
  seo: 'SEO optimizacija',
  'local-seo': 'Local SEO',
  geo: 'Google Business / GEO',
  hosting: 'Hosting i održavanje',
  'google-ads': 'Google Ads',
  'google-maps': 'Google Maps / GMB',
  'graficki-dizajn': 'Grafički dizajn',
  'digitalni-meni': 'Digitalni meni',
  general: 'Opšti upit / konsultacije',
};
---

<div class:list={['cwp-contact', variantClass]} data-cwp-contact>
  <p class="cwp-contact__note" data-i18n="c:contact_form.note">
    Poruka se šalje direktno na naš tim putem šifrovanog kanala. Odgovaramo radnim danom u roku od
    24h.
  </p>

  <span hidden id={`${formId}-str-ok`} data-i18n="c:contact_form.success"
    >Hvala — poruka je primljena. Javićemo se uskoro.</span
  >
  <span hidden id={`${formId}-str-err`} data-i18n="c:contact_form.error">
    Slanje nije uspelo. Pokušajte ponovo ili nas pozovite.
  </span>
  <span hidden id={`${formId}-str-val`} data-i18n="c:contact_form.error_validation"
    >Proverite označena polja.</span
  >

  <div class="cwp-contact__status" id={`${formId}-status`} role="status" aria-live="polite"></div>

  <form id={formId} class="cwp-contact__form" novalidate>
    <input
      type="text"
      name="company"
      class="cwp-contact__hp"
      tabindex="-1"
      autocomplete="off"
      aria-hidden="true"
    />
    <input type="hidden" name="source" value={source} />

    <div class="cwp-contact__grid">
      <div class="cwp-contact__field">
        <label class="cwp-contact__label" for={`${formId}-cat`} data-i18n="c:contact_form.category"
          >Kategorija upita</label
        >
        <div class="cwp-contact__select-wrap">
          <select id={`${formId}-cat`} name="category" class="cwp-contact__select" required>
            {
              CONTACT_CATEGORY_SLUGS.map((slug) => (
                <option value={slug} selected={slug === defaultCategory} data-i18n={catI18n(slug)}>
                  {defaultLabels[slug]}
                </option>
              ))
            }
          </select>
        </div>
      </div>

      <div class="cwp-contact__field cwp-contact__field--span2">
        <label class="cwp-contact__label" for={`${formId}-name`} data-i18n="c:contact_form.name"
          >Ime i prezime</label
        >
        <input
          id={`${formId}-name`}
          name="name"
          type="text"
          class="cwp-contact__input"
          autocomplete="name"
          required
          minlength="2"
          maxlength="120"
          placeholder="npr. Ana Petrović"
          data-i18n-placeholder="c:contact_form.ph_name"
        />
      </div>

      <div class="cwp-contact__field">
        <label class="cwp-contact__label" for={`${formId}-email`} data-i18n="c:contact_form.email"
          >Email</label
        >
        <input
          id={`${formId}-email`}
          name="email"
          type="email"
          class="cwp-contact__input"
          autocomplete="email"
          required
          placeholder="vasa@firma.rs"
          data-i18n-placeholder="c:contact_form.ph_email"
        />
      </div>

      <div class="cwp-contact__field">
        <label class="cwp-contact__label" for={`${formId}-phone`} data-i18n="c:contact_form.phone"
          >Telefon (opciono)</label
        >
        <input
          id={`${formId}-phone`}
          name="phone"
          type="tel"
          class="cwp-contact__input"
          autocomplete="tel"
          maxlength="40"
          placeholder="+381 ..."
          data-i18n-placeholder="c:contact_form.ph_phone"
        />
      </div>

      <div class="cwp-contact__field cwp-contact__field--span2">
        <label class="cwp-contact__label" for={`${formId}-msg`} data-i18n="c:contact_form.message"
          >Kratak brief</label
        >
        <textarea
          id={`${formId}-msg`}
          name="message"
          class="cwp-contact__textarea"
          rows={variant === 'compact' ? 4 : 5}
          required
          minlength="10"
          maxlength="8000"
          placeholder="Cilj projekta, rokovi, budžet, linkovi ka postojećem sajtu ili konkurentima..."
          data-i18n-placeholder="c:contact_form.ph_message"></textarea>
      </div>
    </div>

    <p class="cwp-contact__privacy" data-i18n="c:contact_form.privacy_hint">
      Slanjem formulara prihvatate da obrađujemo podatke isključivo radi odgovora na upit, u skladu
      sa politikom privatnosti.
    </p>

    <div class="cwp-contact__actions">
      <button
        type="submit"
        class="btn-primary cwp-contact__submit"
        data-i18n="c:contact_form.submit"
      >
        Pošalji upit
      </button>
      <span
        class="cwp-contact__sending"
        id={`${formId}-sending`}
        hidden
        data-i18n="c:contact_form.sending">Šaljemo…</span
      >
    </div>
  </form>
</div>

<script is:inline define:vars={{ apiUrl, formId, defaultCategory }}>
  (function () {
    const form = document.getElementById(formId);
    if (!form || !(form instanceof HTMLFormElement)) return;
    const statusEl = document.getElementById(formId + '-status');
    const sendingEl = document.getElementById(formId + '-sending');
    const submitBtn = form.querySelector('.cwp-contact__submit');
    const elOk = document.getElementById(formId + '-str-ok');
    const elErr = document.getElementById(formId + '-str-err');
    const elVal = document.getElementById(formId + '-str-val');

    function txt(el) {
      return (el && el.textContent) || '';
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!statusEl || !sendingEl || !submitBtn) return;
      statusEl.textContent = '';
      statusEl.className = 'cwp-contact__status';

      const fd = new FormData(form);
      const company = String(fd.get('company') || '');
      const payload = {
        name: String(fd.get('name') || '').trim(),
        email: String(fd.get('email') || '').trim(),
        phone: String(fd.get('phone') || '').trim(),
        category: String(fd.get('category') || ''),
        message: String(fd.get('message') || '').trim(),
        source: String(fd.get('source') || '').trim(),
        company,
      };

      if (!payload.name || !payload.email || !payload.category || payload.message.length < 10) {
        statusEl.textContent = txt(elVal);
        statusEl.classList.add('cwp-contact__status--error');
        return;
      }

      submitBtn.setAttribute('disabled', 'disabled');
      sendingEl.hidden = false;

      try {
        const res = await fetch(apiUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.ok) {
          statusEl.textContent = txt(elOk);
          statusEl.classList.add('cwp-contact__status--ok');
          form.reset();
          const sel = form.querySelector('[name="category"]');
          if (sel instanceof HTMLSelectElement) sel.value = defaultCategory;
        } else {
          statusEl.textContent = data.error === 'validation' ? txt(elVal) : txt(elErr);
          statusEl.classList.add('cwp-contact__status--error');
        }
      } catch {
        statusEl.textContent = txt(elErr);
        statusEl.classList.add('cwp-contact__status--error');
      } finally {
        submitBtn.removeAttribute('disabled');
        sendingEl.hidden = true;
        try {
          if (typeof window.__cwpRefreshI18n === 'function') window.__cwpRefreshI18n();
        } catch {
          // i18n hook optional
          void 0;
        }
      }
    });
  })();
</script>
