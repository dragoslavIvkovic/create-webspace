---

---

<div
  id="cwp-cookie-banner"
  class="cwp-cookie-banner"
  role="dialog"
  aria-modal="true"
  aria-labelledby="cwp-cookie-banner-title"
  aria-describedby="cwp-cookie-banner-desc"
  aria-hidden="true"
  hidden
>
  <div class="cwp-cookie-banner__panel">
    <h2 id="cwp-cookie-banner-title" class="cwp-cookie-banner__title" data-i18n="c:cookie.title">
      Kolačići na sajtu
    </h2>
    <p id="cwp-cookie-banner-desc" class="cwp-cookie-banner__text" data-i18n="c:cookie.body">
      Koristimo neophodne kolačiće radi rada sajta i anonimne statistike u skladu sa politikom
      privatnosti. Možete prihvatiti ili odbiti neesencijalne kolačiće.
    </p>
    <div class="cwp-cookie-banner__actions">
      <button
        type="button"
        class="btn-primary cwp-cookie-banner__btn"
        id="cwp-cookie-accept"
        data-i18n="c:cookie.accept"
      >
        Prihvatam
      </button>
      <button
        type="button"
        class="btn-outline cwp-cookie-banner__btn cwp-cookie-banner__btn--outline"
        id="cwp-cookie-decline"
        data-i18n="c:cookie.decline"
      >
        Odbijam neesencijalne
      </button>
      <a href="#privacy" class="cwp-cookie-banner__link text-link" data-i18n="c:cookie.learn_more"
        >Politika privatnosti</a
      >
    </div>
  </div>
</div>
