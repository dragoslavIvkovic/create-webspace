---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  keywords?: string;
  author?: string;
  dataPage: string;
  bodyClass?: string;
  bodyId?: string;
  headerClass?: string;
  activeSection: 'services' | 'projects' | 'about' | 'contact' | null;
  isHome: boolean;
  showPreloader?: boolean;
  includeScrollTrigger?: boolean;
}

const {
  title,
  description,
  canonical,
  keywords,
  author = 'CreateWebPlace',
  dataPage,
  bodyClass = '',
  bodyId = '',
  headerClass = '',
  activeSection,
  isHome,
  showPreloader = false,
  includeScrollTrigger = true,
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="sr">
  <head>
    {canonical && <link rel="canonical" href={canonical} />}
    <meta charset="UTF-8" />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://cdnjs.cloudflare.com" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="author" content={author} />
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>⚡</text></svg>"
    />
    <slot name="head" />
    <link rel="stylesheet" href={`${base}style.css`} />
    <!-- Same families as typography in public/style.css (avoid duplicate conflicting stacks) -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Pacifico&family=Roboto:ital,wght@0,300;0,400;0,500;0,700;1,400&family=Rubik:wght@300;400;500;600;700&family=Teko:wght@400;500;600;700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Pacifico&family=Roboto:ital,wght@0,300;0,400;0,500;0,700;1,400&family=Rubik:wght@300;400;500;600;700&family=Teko:wght@400;500;600;700&display=swap"
      />
    </noscript>
  </head>
  <body class:list={[bodyClass || false]} id={bodyId || undefined} data-page={dataPage}>
    <a class="skip-link" href="#main-content" data-i18n="c:aria.skip_main">Preskoči na sadržaj</a>
    {
      showPreloader && (
        <div id="preloader">
          <div class="loader-content">
            <span class="logo-text">CreateWebPlace</span>
            <div class="loader-bar" />
          </div>
        </div>
      )
    }
    <SiteHeader isHome={isHome} activeSection={activeSection} headerClass={headerClass} />
    <slot />
    <SiteFooter isHome={isHome} includeScrollTrigger={includeScrollTrigger} />
  </body>
</html>
