{
  "name": "createwebplace-site",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/sync-public.mjs",
    "dev": "astro dev",
    "prebuild": "node scripts/sync-public.mjs",
    "build": "astro build",
    "cf-typegen": "wrangler types",
    "deploy": "wrangler deploy",
    "deploy:cf": "wrangler deploy",
    "preview": "astro build && wrangler dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.5.1",
    "astro": "^6.3.3",
    "resend": "^6.12.3",
    "sharp": "^0.34.0",
    "wrangler": "^4.83.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,astro}": [
      "eslint --fix --no-warn-ignored"
    ],
    "*.{js,cjs,mjs,ts,astro,css,html,json,md}": [
      "prettier --write --ignore-unknown"
    ]
  }
}
